# Copy this file to .env (for `vercel dev`) and/or set these as
# Environment Variables in your Vercel project settings.
# NEVER commit your real .env file or API key to git.

# Your Google AI Studio (Gemini) API key. Get one for free, no credit card
# required, at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Optional: override which model the backend calls.
# Check https://ai.google.dev/gemini-api/docs/models for current free-tier
# eligible models (e.g. gemini-2.5-flash, gemini-2.5-flash-lite).
GEMINI_MODEL=gemini-2.5-flash
